{
  "name": "imposia-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "node --import tsx scripts/clean-package-dists.ts && tsc -b && node --import tsx scripts/build-core-browser.ts && node --import tsx scripts/build-demo.ts && node --import tsx scripts/check-core-package-boundary.ts",
    "build:demo": "node --import tsx scripts/build-demo.ts",
    "check:core-boundary": "node --import tsx scripts/check-core-package-boundary.ts",
    "setup:browsers": "playwright install chromium firefox webkit",
    "preflight": "node --import tsx scripts/preflight.ts",
    "typecheck": "tsc -b --pretty false && tsc --noEmit --pretty false -p tests/typecheck/tsconfig.json && tsc --noEmit --pretty false -p examples/demo/tsconfig.json",
    "lint": "biome check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/core",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:parity": "playwright test tests/e2e/browser-core-fragmentation.spec.ts tests/e2e/browser-core-breaks.spec.ts",
    "licenses": "node --import tsx scripts/licenses.ts",
    "verify": "node --import tsx scripts/capture-check.ts",
    "check": "pnpm preflight && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm test:e2e && pnpm run licenses"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.7",
    "@imposia/react": "workspace:*",
    "@playwright/test": "1.57.0",
    "@types/node": "24.10.1",
    "@types/pixelmatch": "5.2.6",
    "@types/pngjs": "6.0.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.25.12",
    "pixelmatch": "7.1.0",
    "pdfjs-dist": "5.4.530",
    "playwright": "1.57.0",
    "pngjs": "7.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  }
}
