{
  "name": "@imposia/viewer",
  "version": "0.1.0",
  "description": "Browser-native viewer for canonical Imposia page documents and PDF.js documents.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EungyuCho/imposia.git",
    "directory": "packages/viewer"
  },
  "homepage": "https://imposia.pages.dev",
  "bugs": {
    "url": "https://github.com/EungyuCho/imposia/issues"
  },
  "keywords": [
    "viewer",
    "pdf",
    "pagination",
    "paged-media",
    "browser",
    "pdfjs"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": [
    "./src/styles.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "dependencies": {
    "@imposia/core": "workspace:^",
    "pdfjs-dist": "5.4.530"
  },
  "publishConfig": {
    "access": "public"
  }
}
