{
  "name": "@imposia/client",
  "version": "0.1.2",
  "description": "Browser-native paginated document and viewer APIs for HTML/CSS publishing.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EungyuCho/imposia.git",
    "directory": "packages/client"
  },
  "homepage": "https://imposia.pages.dev",
  "bugs": {
    "url": "https://github.com/EungyuCho/imposia/issues"
  },
  "keywords": [
    "pagination",
    "paged-media",
    "html",
    "css",
    "viewer",
    "browser"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": [
    "./src/styles.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@imposia/core": "workspace:*",
    "@imposia/viewer": "workspace:*"
  }
}
