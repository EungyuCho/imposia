{
  "name": "@imposia/core",
  "version": "0.1.1",
  "description": "Browser-native HTML/CSS pagination, publishing diagnostics, and reflowable EPUB export.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EungyuCho/imposia.git",
    "directory": "packages/core"
  },
  "homepage": "https://imposia.pages.dev",
  "bugs": {
    "url": "https://github.com/EungyuCho/imposia/issues"
  },
  "keywords": [
    "pagination",
    "paged-media",
    "html",
    "css",
    "epub",
    "browser"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "parse5": "8.0.0",
    "postcss": "8.5.19"
  }
}
