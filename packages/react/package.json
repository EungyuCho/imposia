{
  "name": "@imposia/react",
  "version": "0.1.1",
  "description": "React adapter for browser-native HTML/CSS pagination, native print, and EPUB export.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EungyuCho/imposia.git",
    "directory": "packages/react"
  },
  "homepage": "https://imposia.pages.dev",
  "bugs": {
    "url": "https://github.com/EungyuCho/imposia/issues"
  },
  "keywords": [
    "react",
    "pagination",
    "paged-media",
    "html",
    "css",
    "epub"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": [
    "./src/styles.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@imposia/client": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
