{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!!.codegraph",
      "!!node_modules",
      "!!packages/*/node_modules",
      "!!packages/*/dist",
      "!!packages/core/dist",
      "!!packages/viewer/dist",
      "!examples/react/app.js",
      "!examples/demo/app.js",
      "!!artifacts",
      "!!output",
      "!!benchmarks/latest.*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "html": {
    "parser": {
      "interpolation": true
    }
  }
}
